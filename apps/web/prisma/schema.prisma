generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLAYER
  ADMIN
}

enum CycleStatus {
  REGISTRATION
  TESTING
  ACTIVE
  RESOLUTION
}

enum CycleRuleset {
  LEGACY
  SEASON_4
  SEASON_5
}

enum SeasonFiveCharacterClass {
  DRUNKEN_MONK
  RETIRED_WARRIOR
  DEMENTED_WIZARD
  BURNT_OUT_ROGUE
}

enum SeasonFiveLocationKind {
  HOME
  LAKE
  SEA
}

enum SeasonFiveActionKind {
  AT_HOME
  TRAVELING
  FISHING
}

enum SeasonFiveGearSlot {
  ROD
  BAIT
  PACK
  TRINKET
}

enum SeasonFiveGearRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
}

enum SeasonFiveFishRarity {
  COMMON
  UNCOMMON
  RARE
  LEGENDARY
}

enum SeasonFiveMapTerrain {
  GRASS
  FOREST
  WATER
  COAST
  SWAMP
  HILL
  MOUNTAIN
  ROAD
}

enum SeasonFiveMapRole {
  NONE
  HOME
  FISHING_SPOT
  SHOP
  EVENT
  SECRET_LAKE
}

enum FortressAction {
  GROW
  ATTACK
}

enum FortressKind {
  PLAYER
  MEGA
  UNICORN_DECOY
  LOOT_CAMP
  DWARF_RUNE
}

enum LootCampVariant {
  CLASSIC
  RICH
  CHAOS
}

enum FortressRace {
  DWARFS
  UNSTABLE_UNICORNS
  SPACE_MURINES
  ORKS
}

enum FortressDoctrine {
  DWARF_HOLDFAST
  DWARF_WATCHKEEPERS
  ORK_MARAUDERS
  ORK_SIEGEBREAKERS
  MURINE_CONVOY_COMMAND
  MURINE_RAPID_RESPONSE
  UNICORN_GLITTER_FRONTIER
  UNICORN_VEILED_NETWORK
}

enum CastleUpgradeSpecialization {
  POINTS
  FOOD
  MILITARY
  DEFENSE
  TRADE
}

enum RaceAbilityKind {
  HOME_OF_A_BOSS_BUFF
  DWARF_DEEP_MINING_COOLDOWN
  DWARF_ECONOMY_SURGE
  DWARF_COMBAT_SURGE
  DWARF_RUNE_SUPPRESSION
  DWARF_RUNE_GRUDGES
  DWARF_SLOW_ATTACKS
  DWARF_ECONOMY_HALT
  ORK_WAAAGH
  SPACE_MURINE_STIM
  SPACE_MURINE_INSTANT_RECALL
  SPACE_MURINE_GARRISON_INSTANT_RECALL
  UNICORN_SHATTERED_REALITY
  UNICORN_TELEPORT
  UNICORN_COMBAT_SURGE
  UNICORN_ECONOMY_SURGE
}

enum OrkScrapEventReason {
  DIRECT_RAID
  TILE_BATTLE
  HOME_OF_A_BATTLE
  LOOT_CAMP
  BOSS_ORDER
  WAAAGH_INVESTMENT
}

enum OrkBossOrderKind {
  MORE_DAKKA
  LOOT_WAGONS
  PATCH_DA_FORT
}

enum OrkWaaaghInvestmentKind {
  KEEP_IT_LOUD
  BIGGER_SHOUTIN
  DA_GREEN_TIDE
}

enum ScoreEventType {
  GROW_TICK
  ATTACK_SELF
  ATTACK_TARGET
  TILE_CLAIM
  TILE_BATTLE_REWARD
  BATTLEFIELD_REWARD
  MEGA_DAMAGE
  MEGA_DESTROY_BONUS
  UNICORN_DECOY_DESTROY
  LOOT_CAMP_REWARD
  FORTRESS_UPGRADE_PURCHASE
  FORTRESS_UPGRADE_SLAYER_BONUS
  FORTRESS_LOCATION_SHUFFLE_COST
  TRADE_WAGON_SLOT_PURCHASE
  DWARF_DEEP_MINING_POINTS
  DWARF_RUNE_BOUNTY
  RENAME_COST
  MANUAL_ADJUST
  TRADE_DELIVERY
  CONVOY_INTERCEPTION
  NUKE_COMPONENT_AWARDED
  NUKE_LAUNCH
}

enum NukeComponentKind {
  FUEL
  ROCKET
  WRATH_OF_A
}

enum NukeComponentRoundStatus {
  OPEN
  RESOLVED
}

enum DwarfDeepMiningOutcome {
  RICH_VEIN
  ORE_SURGE
  BATTLE_RUNES
  FACTION_SEAL
  BURIED_WARBAND
  CAVE_IN
  UNSTABLE_TUNNELS
  SHAFT_COLLAPSE
}

enum UnicornShatteredRealityOutcome {
  MIRROR_HOST
  PRISMATIC_SURGE
  LUCKY_GALLOP
}

enum WinnerRequestStatus {
  SUBMITTED
  NEEDS_SIMPLIFICATION
  ACCEPTED
  REJECTED
  UNDER_ADMIN_REVIEW
}

enum CommunityWishStatus {
  PROPOSALS_OPEN
  OPEN
  RESOLVED
  TIE_REQUIRES_ADMIN
  NO_PROPOSALS
}

enum ChatMessageType {
  TEXT
  GIF
}

enum ArcadeGameType {
  SLOTS
  DICE
  WHEEL
}

enum ArcadeTransactionKind {
  SEASON_PAYOUT
  GAME_RESULT
  LOOT_BOX_PURCHASE
  LOOT_BOX_OPEN
  LOOT_BOX_DUPLICATE_REFUND
}

enum ArcadeLootBoxType {
  UNIT
  FORTRESS
}

enum ArcadeCosmeticSlot {
  UNIT
  FORTRESS
}

enum BattlefieldStatus {
  ACTIVE
  RESOLVED
}

enum BattlefieldSide {
  ATTACKER
  DEFENDER
}

enum DiplomacyRelationStatus {
  NEUTRAL
  ALLIANCE_PENDING
  ALLIED
  ENEMY
  WAR_PENDING
  WAR
  PEACE_PENDING
}

enum ArmyOrderType {
  GUARD
  ESCORT
  RAID
  CAMPAIGN
}

enum ArmyOrderStatus {
  ACTIVE
  TRANSFERRED
  RETURNED
  CANCELED
}

enum TerritoryCampaignStatus {
  BUILDING
  SIEGE_WARNING
  ENGAGED
  RESOLVED
  CANCELED
}

model User {
  id                        String                         @id @default(cuid())
  name                      String?
  email                     String?                        @unique
  emailVerified             DateTime?
  image                     String?
  role                      UserRole                       @default(PLAYER)
  lastReadChatAt            DateTime?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  accounts                  Account[]
  sessions                  Session[]
  fortresses                Fortress[]
  seasonFiveCharacters      SeasonFiveCharacter[]
  chatMessages              ChatMessage[]
  scoreEventsAsActor        ScoreEvent[]                   @relation("ScoreEventActor")
  winnerRequests            WinnerRequest[]                @relation("WinnerRequestAuthor")
  reviewedRequests          WinnerRequest[]                @relation("WinnerRequestReviewer")
  communityWishProposals    CommunityWishProposal[]        @relation("CommunityWishProposalAuthor")
  communityWishVotes        CommunityWishVote[]            @relation("CommunityWishVoteVoter")
  communityWishEntitlements CommunityWishVoteEntitlement[] @relation("CommunityWishVoteEntitlementUser")
  buildArcadeRuns           BuildArcadeRun[]
  arcadeWallet              ArcadeWallet?
  arcadeTransactions        ArcadeTransaction[]
  arcadeLootBoxPurchases    ArcadeLootBoxPurchase[]
  arcadeCosmeticUnlocks     ArcadeCosmeticUnlock[]
  resolvedCommunityWishTies CycleHistory[]                 @relation("CommunityWishAdminResolver")
  wonCycles                 Cycle[]                        @relation("CycleWinner")
  cycleHistoriesWon         CycleHistory[]                 @relation("CycleHistoryWinner")
  unitCosmeticVariant       String?
  fortressCosmeticVariant   String?
  cosmeticUnlockedAt        DateTime?
}

model Account {
  id                       String   @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?  @db.Text
  access_token             String?  @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?  @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cycle {
  id                             String                          @id @default(cuid())
  status                         CycleStatus                     @default(REGISTRATION)
  ruleset                        CycleRuleset                    @default(LEGACY)
  registrationStartedAt          DateTime
  registrationEndsAt             DateTime
  testingStartedAt               DateTime?
  testingEndsAt                  DateTime?
  joiningLockedAt                DateTime?
  activeStartedAt                DateTime?
  activeEndsAt                   DateTime?
  resolvedAt                     DateTime?
  winnerId                       String?
  crownedFortressId              String?
  upgradesUnlockedAt             DateTime?
  homeOfABossRespawnsAt          DateTime?
  megaFortressDestroyCount       Int                             @default(0)
  mapLayoutVersion               Int                             @default(1)
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
  winner                         User?                           @relation("CycleWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  crownedFortress                Fortress?                       @relation("CycleCrownedFortress", fields: [crownedFortressId], references: [id], onDelete: SetNull)
  fortresses                     Fortress[]
  chatMessages                   ChatMessage[]
  scoreEvents                    ScoreEvent[]
  gameTicks                      GameTick[]
  attackUnits                    AttackUnit[]
  battlefields                   Battlefield[]
  mapHexOwnerships               MapHexOwnership[]
  tilePressurePriorities         TilePressurePriority[]
  tilePressureStates             TilePressureState[]
  mapHexRoads                    MapHexRoad[]
  diplomacyRelations             DiplomacyRelation[]
  armyOrders                     ArmyOrder[]
  territoryCampaigns             TerritoryCampaign[]
  tradeOffers                    TradeOffer[]
  convoyLegs                     ConvoyLeg[]
  nukeComponentRounds            NukeComponentRound[]
  nukeComponentBids              NukeComponentBid[]
  nukeComponentInventories       NukeComponentInventory[]
  nukeLaunches                   NukeLaunch[]
  covertIncidents                CovertIncident[]
  castleUpgradeProjects          CastleUpgradeProject[]
  homeOfAHolders                 HomeOfAHolder[]
  unicornTemporaryTeleports      UnicornTemporaryTeleport[]
  orkScrapBanks                  OrkScrapBank[]
  orkScrapEvents                 OrkScrapEvent[]
  orkBossOrders                  OrkBossOrder[]
  orkWaaaghInvestments           OrkWaaaghInvestment[]
  winnerRequests                 WinnerRequest[]
  communityWishProposals         CommunityWishProposal[]
  communityWishVoteEntitlements  CommunityWishVoteEntitlement[]
  buildArcadeRuns                BuildArcadeRun[]
  arcadeTransactions             ArcadeTransaction[]
  fortressGarrisons              FortressGarrison[]
  seasonFiveCharacters           SeasonFiveCharacter[]
  seasonFiveFishCatches          SeasonFiveFishCatch[]
  seasonFiveFishingLocations     SeasonFiveFishingLocation[]
  seasonFiveFishingWaterBodies   SeasonFiveFishingWaterBody[]
  seasonFiveMapTiles             SeasonFiveMapTile[]
  battalions                     Battalion[]
  warFronts                      WarFront[]
  warPolicies                    WarPolicy[]
  homeOfABossDamageContributions HomeOfABossDamageContribution[]
  history                        CycleHistory?

  @@index([status])
  @@index([resolvedAt, createdAt], map: "Cycle_resolvedAt_createdAt_idx")
  @@index([status, registrationEndsAt], map: "Cycle_status_registrationEndsAt_idx")
  @@index([status, testingEndsAt], map: "Cycle_status_testingEndsAt_idx")
  @@index([status, activeStartedAt], map: "Cycle_status_activeStartedAt_idx")
  @@index([updatedAt], map: "Cycle_updatedAt_idx")
  @@index([winnerId])
  @@index([crownedFortressId])
}

model SeasonFiveCharacter {
  id                    String                         @id @default(cuid())
  userId                String
  cycleId               String
  name                  String
  class                 SeasonFiveCharacterClass
  level                 Int                            @default(1)
  experience            Int                            @default(0)
  skillPoints           Int                            @default(0)
  totalFishCaught       Int                            @default(0)
  biggestFishCm         Int                            @default(0)
  inventoryCapacity     Int                            @default(12)
  actionKind            SeasonFiveActionKind           @default(AT_HOME)
  currentLocationId     String?
  destinationLocationId String?
  actionStartedAt       DateTime?
  actionCompletesAt     DateTime?
  lastResolvedAt        DateTime                       @default(now())
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  user                  User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle                 Cycle                          @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  currentLocation       SeasonFiveFishingLocation?     @relation("SeasonFiveCurrentLocation", fields: [currentLocationId], references: [id], onDelete: SetNull)
  destinationLocation   SeasonFiveFishingLocation?     @relation("SeasonFiveDestinationLocation", fields: [destinationLocationId], references: [id], onDelete: SetNull)
  gear                  SeasonFiveGear[]
  inventoryItems        SeasonFiveInventoryItem[]
  fishCatches           SeasonFiveFishCatch[]
  skillPurchases        SeasonFiveSkillPurchase[]
  keyItems              SeasonFiveKeyItem[]
  waterBodyDiscoveries  SeasonFiveWaterBodyDiscovery[]

  @@unique([cycleId, userId])
  @@index([userId])
  @@index([cycleId, totalFishCaught])
  @@index([cycleId, biggestFishCm])
  @@index([actionKind, actionCompletesAt])
}

model SeasonFiveFishingLocation {
  id                    String                      @id @default(cuid())
  cycleId               String
  key                   String
  name                  String
  kind                  SeasonFiveLocationKind
  xPercent              Float
  yPercent              Float
  travelMinutes         Int
  catchDifficulty       Int                         @default(1)
  minFishCm             Int
  maxFishCm             Int
  inventoryPressure     Int                         @default(1)
  tileId                String?
  waterBodyId           String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  cycle                 Cycle                       @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  tile                  SeasonFiveMapTile?          @relation(fields: [tileId], references: [id], onDelete: SetNull)
  waterBody             SeasonFiveFishingWaterBody? @relation(fields: [waterBodyId], references: [id], onDelete: SetNull)
  currentCharacters     SeasonFiveCharacter[]       @relation("SeasonFiveCurrentLocation")
  destinationCharacters SeasonFiveCharacter[]       @relation("SeasonFiveDestinationLocation")
  fishCatches           SeasonFiveFishCatch[]

  @@unique([cycleId, key])
  @@index([cycleId, kind])
  @@index([tileId])
  @@index([waterBodyId])
}

model SeasonFiveFishingWaterBody {
  id                String                         @id @default(cuid())
  cycleId           String
  key               String
  name              String
  profileKey        String
  maxStock          Int
  currentStock      Int
  regenPerHour      Int
  lastRegeneratedAt DateTime
  levelRequired     Int                            @default(1)
  requiredGearKey   String?
  hidden            Boolean                        @default(false)
  catchDifficulty   Int                            @default(1)
  minFishCm         Int
  maxFishCm         Int
  inventoryPressure Int                            @default(1)
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  cycle             Cycle                          @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fishingLocations  SeasonFiveFishingLocation[]
  discoveries       SeasonFiveWaterBodyDiscovery[]

  @@unique([cycleId, key])
  @@index([cycleId, profileKey])
  @@index([cycleId, hidden])
  @@index([cycleId, lastRegeneratedAt])
}

model SeasonFiveMapTile {
  id               String                      @id @default(cuid())
  cycleId          String
  key              String
  row              Int
  col              Int
  xPercent         Float
  yPercent         Float
  terrain          SeasonFiveMapTerrain
  visualVariant    Int                         @default(0)
  role             SeasonFiveMapRole           @default(NONE)
  roleLabel        String?
  hidden           Boolean                     @default(false)
  discoveredAt     DateTime?
  expiresAt        DateTime?
  requiredKey      String?
  roleSeedKey      String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  cycle            Cycle                       @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fishingLocations SeasonFiveFishingLocation[]

  @@unique([cycleId, key])
  @@unique([cycleId, row, col])
  @@index([cycleId, role])
  @@index([cycleId, hidden])
  @@index([cycleId, expiresAt])
}

model SeasonFiveGear {
  id          String               @id @default(cuid())
  characterId String
  slot        SeasonFiveGearSlot
  key         String
  name        String
  rarity      SeasonFiveGearRarity @default(COMMON)
  power       Int                  @default(0)
  equipped    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  character   SeasonFiveCharacter  @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, key])
  @@index([characterId, slot, equipped])
}

model SeasonFiveFishCatch {
  id             String                    @id @default(cuid())
  cycleId        String
  characterId    String
  locationId     String
  speciesKey     String
  speciesName    String
  rarity         SeasonFiveFishRarity
  sizeCm         Int
  inventorySlots Int                       @default(1)
  caughtAt       DateTime                  @default(now())
  unloadedAt     DateTime?
  cycle          Cycle                     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  character      SeasonFiveCharacter       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  location       SeasonFiveFishingLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  inventoryItem  SeasonFiveInventoryItem?

  @@index([cycleId, caughtAt])
  @@index([cycleId, sizeCm])
  @@index([characterId, unloadedAt])
}

model SeasonFiveInventoryItem {
  id          String              @id @default(cuid())
  characterId String
  fishCatchId String              @unique
  slots       Int                 @default(1)
  unloadedAt  DateTime?
  createdAt   DateTime            @default(now())
  character   SeasonFiveCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
  fishCatch   SeasonFiveFishCatch @relation(fields: [fishCatchId], references: [id], onDelete: Cascade)

  @@index([characterId, unloadedAt])
}

model SeasonFiveSkillPurchase {
  id          String              @id @default(cuid())
  characterId String
  nodeKey     String
  purchasedAt DateTime            @default(now())
  character   SeasonFiveCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, nodeKey])
  @@index([characterId])
}

model SeasonFiveKeyItem {
  id          String              @id @default(cuid())
  characterId String
  key         String
  name        String
  createdAt   DateTime            @default(now())
  character   SeasonFiveCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, key])
  @@index([characterId])
}

model SeasonFiveWaterBodyDiscovery {
  id           String                     @id @default(cuid())
  characterId  String
  waterBodyId  String
  discoveredAt DateTime                   @default(now())
  expiresAt    DateTime
  character    SeasonFiveCharacter        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  waterBody    SeasonFiveFishingWaterBody @relation(fields: [waterBodyId], references: [id], onDelete: Cascade)

  @@unique([characterId, waterBodyId])
  @@index([characterId, expiresAt])
  @@index([waterBodyId, expiresAt])
}

model Fortress {
  id                             String                              @id @default(cuid())
  cycleId                        String
  ownerId                        String
  commanderName                  String
  commanderNameRegisteredAt      DateTime?
  name                           String
  points                         Int                                 @default(0)
  gold                           Int                                 @default(0)
  unitsKilled                    Int                                 @default(0)
  goblinsKilled                  Int                                 @default(0)
  resourcesStolen                Int                                 @default(0)
  deliveredCargoValue            Int                                 @default(0)
  interceptedCargoValue          Int                                 @default(0)
  level                          Int                                 @default(0)
  food                           Int                                 @default(0)
  army                           Int                                 @default(0)
  recruitmentQueue               Int                                 @default(0)
  minersAssigned                 Int                                 @default(10)
  farmersAssigned                Int                                 @default(10)
  recruitersAssigned             Int                                 @default(5)
  pressureWorkersAssigned        Int                                 @default(0)
  race                           FortressRace?
  doctrine                       FortressDoctrine?
  doctrineChangedAt              DateTime?
  fortressKind                   FortressKind                        @default(PLAYER)
  lootCampVariant                LootCampVariant?
  isNpc                          Boolean                             @default(false)
  health                         Int                                 @default(0)
  maxHealth                      Int                                 @default(0)
  expiresAt                      DateTime?
  sizeTiles                      Int                                 @default(1)
  iconLabel                      String?
  unicornDecoySourceFortressId   String?
  unicornDecoyLevel              Int?
  currentAction                  FortressAction                      @default(GROW)
  targetFortressId               String?
  unitSpriteVariant              String                              @default("unit-1")
  locationShuffleCount           Int                                 @default(0)
  tradeWagonSlotPurchases        Int                                 @default(0)
  mapX                           Int
  mapY                           Int
  joinedAt                       DateTime                            @default(now())
  createdAt                      DateTime                            @default(now())
  updatedAt                      DateTime                            @updatedAt
  cycle                          Cycle                               @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  owner                          User                                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  targetFortress                 Fortress?                           @relation("FortressTarget", fields: [targetFortressId], references: [id], onDelete: SetNull)
  attackers                      Fortress[]                          @relation("FortressTarget")
  unicornDecoySourceFortress     Fortress?                           @relation("UnicornDecoySource", fields: [unicornDecoySourceFortressId], references: [id], onDelete: Cascade)
  unicornDecoys                  Fortress[]                          @relation("UnicornDecoySource")
  outboundAttackUnits            AttackUnit[]                        @relation("AttackUnitAttacker")
  inboundAttackUnits             AttackUnit[]                        @relation("AttackUnitTarget")
  crownedCycles                  Cycle[]                             @relation("CycleCrownedFortress")
  scoreEventsAsFortress          ScoreEvent[]                        @relation("ScoreEventFortress")
  scoreEventsAsTarget            ScoreEvent[]                        @relation("ScoreEventTargetFortress")
  castleUpgradeSpecializations   CastleUpgradeSpecializationChoice[]
  castleUpgradeProjects          CastleUpgradeProject[]
  raceAbilityActivations         RaceAbilityActivation[]
  orkScrapBank                   OrkScrapBank?
  orkScrapEvents                 OrkScrapEvent[]                     @relation("OrkScrapEventFortress")
  orkScrapTargetedEvents         OrkScrapEvent[]                     @relation("OrkScrapEventTargetFortress")
  orkBossOrders                  OrkBossOrder[]
  orkWaaaghInvestments           OrkWaaaghInvestment[]
  targetedRaceAbilityActivations RaceAbilityActivation[]             @relation("RaceAbilityTargetFortress")
  runeRaceAbilityActivations     RaceAbilityActivation[]             @relation("RaceAbilityRuneFortress")
  dwarfGrudges                   DwarfGrudge[]                       @relation("DwarfGrudgeOwner")
  grudgedBy                      DwarfGrudge[]                       @relation("DwarfGrudgeTarget")
  deepMiningRolls                DwarfDeepMiningRoll[]               @relation("DwarfDeepMiningOwner")
  deepMiningRuneRolls            DwarfDeepMiningRoll[]               @relation("DwarfDeepMiningRune")
  deepMiningTargetedBy           DwarfDeepMiningRoll[]               @relation("DwarfDeepMiningTarget")
  ownedMapHexes                  MapHexOwnership[]                   @relation("MapHexOwner")
  tilePressurePriorities         TilePressurePriority[]
  tilePressureStates             TilePressureState[]
  diplomacyRelationsA            DiplomacyRelation[]                 @relation("DiplomacyRelationFortressA")
  diplomacyRelationsB            DiplomacyRelation[]                 @relation("DiplomacyRelationFortressB")
  armyOrders                     ArmyOrder[]
  attackingCampaigns             TerritoryCampaign[]                 @relation("TerritoryCampaignAttacker")
  defendingCampaigns             TerritoryCampaign[]                 @relation("TerritoryCampaignDefender")
  sentTradeOffers                TradeOffer[]                        @relation("TradeOfferSender")
  receivedTradeOffers            TradeOffer[]                        @relation("TradeOfferReceiver")
  outboundConvoyLegs             ConvoyLeg[]                         @relation("ConvoyLegSender")
  inboundConvoyLegs              ConvoyLeg[]                         @relation("ConvoyLegReceiver")
  nukeComponentBids              NukeComponentBid[]
  nukeComponentInventories       NukeComponentInventory[]
  launchedNukes                  NukeLaunch[]                        @relation("NukeLaunchLauncher")
  targetedNukes                  NukeLaunch[]                        @relation("NukeLaunchTarget")
  covertIncidentsAsRaider        CovertIncident[]                    @relation("CovertIncidentRaider")
  covertIncidentsAsDetector      CovertIncident[]                    @relation("CovertIncidentDetector")
  homeOfAHoldings                HomeOfAHolder[]                     @relation("HomeOfAHolderFortress")
  homeOfABannerHoldings          HomeOfAHolder[]                     @relation("HomeOfABannerFortress")
  homeOfABossDamageContributions HomeOfABossDamageContribution[]
  attackerBannerBattlefields     Battlefield[]                       @relation("BattlefieldAttackerBanner")
  defenderBannerBattlefields     Battlefield[]                       @relation("BattlefieldDefenderBanner")
  targetedBattlefields           Battlefield[]                       @relation("BattlefieldTargetFortress")
  battlefieldParticipants        BattlefieldParticipant[]
  unicornTemporaryTeleports      UnicornTemporaryTeleport[]          @relation("UnicornTeleportFortress")
  unicornTemporaryTeleportDecoy  UnicornTemporaryTeleport?           @relation("UnicornTeleportDecoy")
