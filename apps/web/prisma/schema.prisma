  waaaghInvestmentId String?
  createdAt          DateTime             @default(now())
  cycle              Cycle                @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress           Fortress             @relation("OrkScrapEventFortress", fields: [fortressId], references: [id], onDelete: Cascade)
  targetFortress     Fortress?            @relation("OrkScrapEventTargetFortress", fields: [targetFortressId], references: [id], onDelete: SetNull)
  bossOrder          OrkBossOrder?        @relation(fields: [bossOrderId], references: [id], onDelete: SetNull)
  waaaghInvestment   OrkWaaaghInvestment? @relation(fields: [waaaghInvestmentId], references: [id], onDelete: SetNull)

  @@index([cycleId, fortressId, createdAt])
  @@index([targetFortressId])
  @@index([battlefieldId])
  @@index([attackUnitId])
}

model OrkBossOrder {
  id          String           @id @default(cuid())
  cycleId     String
  fortressId  String
  kind        OrkBossOrderKind
  scrapCost   Int
  goldCost    Int
  activeFrom  DateTime
  activeUntil DateTime
  usedAt      DateTime         @default(now())
  createdAt   DateTime         @default(now())
  cycle       Cycle            @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress    Fortress         @relation(fields: [fortressId], references: [id], onDelete: Cascade)
  scrapEvents OrkScrapEvent[]

  @@index([cycleId, fortressId, activeUntil])
  @@index([fortressId, kind, usedAt])
}

model OrkWaaaghInvestment {
  id                 String                  @id @default(cuid())
  cycleId            String
  fortressId         String
  waaaghActivationId String
  kind               OrkWaaaghInvestmentKind
  scrapCost          Int
  createdAt          DateTime                @default(now())
  cycle              Cycle                   @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress           Fortress                @relation(fields: [fortressId], references: [id], onDelete: Cascade)
  waaaghActivation   RaceAbilityActivation   @relation(fields: [waaaghActivationId], references: [id], onDelete: Cascade)
  scrapEvents        OrkScrapEvent[]

  @@unique([waaaghActivationId, kind])
  @@index([cycleId, fortressId, createdAt])
}

model DwarfGrudge {
  id               String   @id @default(cuid())
  fortressId       String
  targetFortressId String
  slot             Int
  bonusMultiplier  Int      @default(1)
  createdAt        DateTime @default(now())
  fortress         Fortress @relation("DwarfGrudgeOwner", fields: [fortressId], references: [id], onDelete: Cascade)
  targetFortress   Fortress @relation("DwarfGrudgeTarget", fields: [targetFortressId], references: [id], onDelete: Cascade)

  @@unique([fortressId, slot])
  @@unique([fortressId, targetFortressId])
  @@index([targetFortressId])
}

model AttackUnit {
  id                         String           @id @default(cuid())
  cycleId                    String
  attackerFortressId         String
  targetFortressId           String
  reinforcementBattlefieldId String?
  reinforcementBattalionId   String?
  reinforcementSide          BattlefieldSide?
  fortifyTargetTileId        String?
  armyAmount                 Int              @default(1)
  defenderArmyAtBattleStart  Int?
  resolvedAttackPower        Int?
  resolvedDefensePower       Int?
  attackerSurvivors          Int?
  attackerRetired            Int?
  attackerReturned           Int?
  defenderLosses             Int?
  pointsLooted               Int?
  foodLooted                 Int?
  armyLooted                 Int?
  launchedAt                 DateTime
  arrivesAt                  DateTime
  recalledAt                 DateTime?
  returnOriginMapX           Int?
  returnOriginMapY           Int?
  resolvedAt                 DateTime?
  cancelledAt                DateTime?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  cycle                      Cycle            @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  attackerFortress           Fortress         @relation("AttackUnitAttacker", fields: [attackerFortressId], references: [id], onDelete: Cascade)
  targetFortress             Fortress         @relation("AttackUnitTarget", fields: [targetFortressId], references: [id], onDelete: Cascade)
  reinforcementBattlefield   Battlefield?     @relation("BattlefieldReinforcements", fields: [reinforcementBattlefieldId], references: [id], onDelete: SetNull)
  reinforcementBattalion     Battalion?       @relation("BattalionReinforcements", fields: [reinforcementBattalionId], references: [id], onDelete: SetNull)

  @@index([cycleId, arrivesAt])
  @@index([fortifyTargetTileId, arrivesAt])
  @@index([cycleId, resolvedAt, cancelledAt, launchedAt], map: "AttackUnit_cycleId_resolvedAt_cancelledAt_launchedAt_idx")
  @@index([reinforcementBattlefieldId, arrivesAt])
  @@index([reinforcementBattalionId, arrivesAt])
  @@index([attackerFortressId, resolvedAt, cancelledAt])
  @@index([targetFortressId])
  @@index([updatedAt, id], map: "AttackUnit_updatedAt_id_idx")
}

model ChatMessage {
  id            String          @id @default(cuid())
  cycleId       String
  authorId      String
  type          ChatMessageType @default(TEXT)
  body          String          @db.Text
  gifProvider   String?
  gifProviderId String?
  gifTitle      String?         @db.Text
  gifPreviewUrl String?         @db.Text
  gifDisplayUrl String?         @db.Text
  gifWidth      Int?
  gifHeight     Int?
  gifSourceUrl  String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  cycle         Cycle           @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  author        User            @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([cycleId, createdAt])
  @@index([authorId, createdAt])
  @@index([createdAt, id], map: "ChatMessage_createdAt_id_idx")
}

model ScoreEvent {
  id               String         @id @default(cuid())
  cycleId          String
  fortressId       String
  actorId          String?
  targetFortressId String?
  eventType        ScoreEventType
  delta            Int
  createdAt        DateTime       @default(now())
  cycle            Cycle          @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress         Fortress       @relation("ScoreEventFortress", fields: [fortressId], references: [id], onDelete: Cascade)
  actor            User?          @relation("ScoreEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetFortress   Fortress?      @relation("ScoreEventTargetFortress", fields: [targetFortressId], references: [id], onDelete: SetNull)

  @@index([cycleId, createdAt])
  @@index([fortressId, createdAt])
  @@index([actorId])
}

model GameTick {
  id        String   @id @default(cuid())
  cycleId   String
  tickAt    DateTime
  createdAt DateTime @default(now())
  cycle     Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, tickAt])
  @@index([tickAt])
}

model WinnerRequest {
  id                    String              @id @default(cuid())
  cycleId               String
  authorId              String
  reviewedById          String?
  requestText           String              @db.Text
  status                WinnerRequestStatus @default(SUBMITTED)
  reviewNotes           String?             @db.Text
  fulfillmentProgress   Int                 @default(0)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  reviewedAt            DateTime?
  cycle                 Cycle               @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  author                User                @relation("WinnerRequestAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reviewedBy            User?               @relation("WinnerRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  cycleHistoryReference CycleHistory?       @relation("CycleHistoryWinnerRequest")

  @@unique([cycleId, authorId])
  @@index([cycleId, status])
}

model CommunityWishProposal {
  id                    String              @id @default(cuid())
  cycleId               String
  authorId              String
  requestText           String              @db.Text
  status                WinnerRequestStatus @default(SUBMITTED)
  reviewNotes           String?             @db.Text
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  cycle                 Cycle               @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  author                User                @relation("CommunityWishProposalAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  votes                 CommunityWishVote[]
  cycleHistoryReference CycleHistory?       @relation("CycleHistoryCommunityWish")

  @@unique([cycleId, authorId])
  @@index([cycleId, createdAt])
}

model BuildArcadeRun {
  id            String   @id @default(cuid())
  cycleId       String
  userId        String
  score         Int      @default(0)
  rewardVariant String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cycle         Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cycleId, userId])
  @@index([cycleId, score])
  @@index([userId])
}

model ArcadeWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([balance])
}

model ArcadeTransaction {
  id           String                @id @default(cuid())
  userId       String
  cycleId      String?
  kind         ArcadeTransactionKind
  gameType     ArcadeGameType?
  amount       Int
  balanceAfter Int
  summary      String                @db.Text
  details      String?               @db.Text
  dedupeKey    String?               @unique
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle        Cycle?                @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([cycleId, createdAt])
}

model ArcadeLootBoxPurchase {
  id              String                @id @default(cuid())
  userId          String
  crateType       ArcadeLootBoxType
  price           Int
  openedAt        DateTime?
  rewardSlot      ArcadeCosmeticSlot?
  rewardVariant   String?
  duplicatePayout Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlock          ArcadeCosmeticUnlock?

  @@index([userId, createdAt])
  @@index([userId, openedAt])
}

model ArcadeCosmeticUnlock {
  id               String                 @id @default(cuid())
  userId           String
  slot             ArcadeCosmeticSlot
  variant          String
  sourcePurchaseId String?                @unique
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePurchase   ArcadeLootBoxPurchase? @relation(fields: [sourcePurchaseId], references: [id], onDelete: SetNull)

  @@unique([userId, slot, variant])
  @@index([userId, slot])
}

model CommunityWishVote {
  id         String                @id @default(cuid())
  proposalId String
  voterId    String
  votes      Int
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  proposal   CommunityWishProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voter      User                  @relation("CommunityWishVoteVoter", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([proposalId, voterId])
  @@index([voterId])
}

model CommunityWishVoteEntitlement {
  id         String   @id @default(cuid())
  cycleId    String
  userId     String
  rank       Int
  voteBudget Int
  createdAt  DateTime @default(now())
  cycle      Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user       User     @relation("CommunityWishVoteEntitlementUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cycleId, userId])
  @@index([userId])
}

model CycleHistory {
  id                               String                 @id @default(cuid())
  cycleId                          String                 @unique
  winnerId                         String
  winnerRequestId                  String?                @unique
  communityWishProposalId          String?                @unique
  winningScore                     Int
  endedAt                          DateTime
  firstSlayerCommanderName         String?                @db.Text
  firstSlayerFortressName          String?                @db.Text
  tieBreakSummary                  String?                @db.Text
  winnerRequestSnapshot            String?                @db.Text
  communityWishSnapshot            String?                @db.Text
  communityWishVoteCount           Int                    @default(0)
  communityWishFulfillmentProgress Int                    @default(0)
  communityWishStatus              CommunityWishStatus    @default(NO_PROPOSALS)
  communityWishProposalEndsAt      DateTime?
  communityWishVotingEndsAt        DateTime?
  communityWishResolvedAt          DateTime?
  communityWishResolvedById        String?
  createdAt                        DateTime               @default(now())
  cycle                            Cycle                  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  winner                           User                   @relation("CycleHistoryWinner", fields: [winnerId], references: [id], onDelete: Restrict)
  winnerRequest                    WinnerRequest?         @relation("CycleHistoryWinnerRequest", fields: [winnerRequestId], references: [id], onDelete: SetNull)
  communityWishProposal            CommunityWishProposal? @relation("CycleHistoryCommunityWish", fields: [communityWishProposalId], references: [id], onDelete: SetNull)
  communityWishResolvedBy          User?                  @relation("CommunityWishAdminResolver", fields: [communityWishResolvedById], references: [id], onDelete: SetNull)

  @@index([winnerId])
  @@index([endedAt])
  @@index([communityWishStatus, communityWishProposalEndsAt])
  @@index([communityWishStatus, communityWishVotingEndsAt])
  @@index([communityWishResolvedById])
}

model RaceSkillPurchase {
  id          String   @id @default(cuid())
  fortressId  String
  nodeKey     String
  purchasedAt DateTime @default(now())
  fortress    Fortress @relation(fields: [fortressId], references: [id], onDelete: Cascade)

  @@unique([fortressId, nodeKey])
  @@index([fortressId])
}

model FortressGarrison {
  id                String       @id @default(cuid())
  cycleId           String
  fortressId        String
  battlefieldId     String?
  tileId            String
  army              Int
  maintenanceDrains Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  cycle             Cycle        @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress          Fortress     @relation(fields: [fortressId], references: [id], onDelete: Cascade)
  battlefield       Battlefield? @relation(fields: [battlefieldId], references: [id], onDelete: Cascade)

  @@unique([battlefieldId, fortressId])
  @@index([cycleId, tileId])
  @@index([fortressId, cycleId])
}

model Battalion {
  id                     String                @id @default(cuid())
  cycleId                String
  fortressId             String
  name                   String
  size                   Int                   @default(0)
  maxSize                Int                   @default(100)
  tier                   Int                   @default(0) // 0=RECRUIT, 1=REGULAR, 2=VETERAN, 3=ELITE
  xp                     Int                   @default(0)
  readyAt                DateTime?
  stance                 String                @default("REST") // FORTIFY, PATROL, TRAINING, AMBUSH, REST, MOBILE
  mode                   String                @default("GUARD") // GUARD, ATTACK, RESERVE, ALLIANCE
  garrisonedAt           String? // tileId if stationed
  stanceLockedUntil      DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  cycle                  Cycle                 @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress               Fortress              @relation(fields: [fortressId], references: [id], onDelete: Cascade)
  assignments            BattalionAssignment[]
  incomingReinforcements AttackUnit[]          @relation("BattalionReinforcements")

  @@unique([cycleId, fortressId, name])
  @@index([cycleId, fortressId])
  @@index([garrisonedAt])
}

model WarFront {
  id                   String                @id @default(cuid())
  cycleId              String
  attackerFortressId   String
  enemyFortressId      String
  status               String                @default("ADVANCING") // ADVANCING, STALLED, VICTORIOUS, DEFEATED, RETREATING
  aggression           String                @default("BALANCED") // CAUTIOUS, BALANCED, AGGRESSIVE
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  cycle                Cycle                 @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  attackerFortress     Fortress              @relation("WarFrontAttacker", fields: [attackerFortressId], references: [id], onDelete: Cascade)
  battalionAssignments BattalionAssignment[]

  @@unique([cycleId, attackerFortressId, enemyFortressId])
  @@index([cycleId, attackerFortressId])
}

model BattalionAssignment {
  id          String    @id @default(cuid())
  battalionId String
  frontId     String
  createdAt   DateTime  @default(now())
  battalion   Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  front       WarFront  @relation(fields: [frontId], references: [id], onDelete: Cascade)

  @@unique([battalionId])
  @@unique([battalionId, frontId])
  @@index([frontId])
}

model WarPolicy {
  id                     String   @id @default(cuid())
  cycleId                String
  fortressId             String
  maxArmySize            Int      @default(500)
  guardPercent           Int      @default(30)
  defaultAggression      String   @default("BALANCED")
  allianceSupportAttack  Boolean  @default(true)
  allianceSupportDefense Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  cycle                  Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress               Fortress @relation(fields: [fortressId], references: [id], onDelete: Cascade)

  @@unique([cycleId, fortressId])
  @@index([cycleId])
}
