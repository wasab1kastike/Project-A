generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ADMIN
}

enum CycleStatus {
  REGISTRATION
  TESTING
  ACTIVE
  RESOLUTION
}

enum FortressAction {
  GROW
  ATTACK
}

enum FortressKind {
  PLAYER
  MEGA
  UNICORN_DECOY
  LOOT_CAMP
  DWARF_RUNE
}

enum LootCampVariant {
  CLASSIC
  RICH
  CHAOS
}

enum FortressRace {
  DWARFS
  UNSTABLE_UNICORNS
  SPACE_MURINES
  ORKS
}

enum CastleUpgradeSpecialization {
  POINTS
  FOOD
  MILITARY
  DEFENSE
}

enum RaceAbilityKind {
  DWARF_DEEP_MINING_COOLDOWN
  DWARF_ECONOMY_SURGE
  DWARF_COMBAT_SURGE
  DWARF_RUNE_SUPPRESSION
  DWARF_RUNE_GRUDGES
  DWARF_SLOW_ATTACKS
  DWARF_ECONOMY_HALT
  ORK_WAAAGH
  SPACE_MURINE_STIM
  SPACE_MURINE_INSTANT_RECALL
  UNICORN_TELEPORT
}

enum OrkScrapEventReason {
  DIRECT_RAID
  TILE_BATTLE
  HOME_OF_A_BATTLE
  LOOT_CAMP
  BOSS_ORDER
  WAAAGH_INVESTMENT
}

enum OrkBossOrderKind {
  MORE_DAKKA
  LOOT_WAGONS
  PATCH_DA_FORT
}

enum OrkWaaaghInvestmentKind {
  KEEP_IT_LOUD
  BIGGER_SHOUTIN
  DA_GREEN_TIDE
}

enum ScoreEventType {
  GROW_TICK
  ATTACK_SELF
  ATTACK_TARGET
  TILE_CLAIM
  TILE_BATTLE_REWARD
  BATTLEFIELD_REWARD
  MEGA_DAMAGE
  MEGA_DESTROY_BONUS
  UNICORN_DECOY_DESTROY
  LOOT_CAMP_REWARD
  FORTRESS_UPGRADE_PURCHASE
  FORTRESS_UPGRADE_SLAYER_BONUS
  FORTRESS_LOCATION_SHUFFLE_COST
  DWARF_DEEP_MINING_POINTS
  DWARF_RUNE_BOUNTY
  RENAME_COST
  MANUAL_ADJUST
}

enum DwarfDeepMiningOutcome {
  RICH_VEIN
  ORE_SURGE
  BATTLE_RUNES
  FACTION_SEAL
  BURIED_WARBAND
  CAVE_IN
  UNSTABLE_TUNNELS
  SHAFT_COLLAPSE
}

enum WinnerRequestStatus {
  SUBMITTED
  NEEDS_SIMPLIFICATION
  ACCEPTED
  REJECTED
  UNDER_ADMIN_REVIEW
}

enum CommunityWishStatus {
  PROPOSALS_OPEN
  OPEN
  RESOLVED
  TIE_REQUIRES_ADMIN
  NO_PROPOSALS
}

enum ChatMessageType {
  TEXT
  GIF
}

enum ArcadeGameType {
  SLOTS
  DICE
  WHEEL
}

enum ArcadeTransactionKind {
  SEASON_PAYOUT
  GAME_RESULT
  LOOT_BOX_PURCHASE
  LOOT_BOX_OPEN
  LOOT_BOX_DUPLICATE_REFUND
}

enum ArcadeLootBoxType {
  UNIT
  FORTRESS
}

enum ArcadeCosmeticSlot {
  UNIT
  FORTRESS
}

enum BattlefieldStatus {
  ACTIVE
  RESOLVED
}

enum BattlefieldSide {
  ATTACKER
  DEFENDER
}

model User {
  id                        String                         @id @default(cuid())
  name                      String?
  email                     String?                        @unique
  emailVerified             DateTime?
  image                     String?
  role                      UserRole                       @default(PLAYER)
  lastReadChatAt            DateTime?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  accounts                  Account[]
  sessions                  Session[]
  fortresses                Fortress[]
  chatMessages              ChatMessage[]
  scoreEventsAsActor        ScoreEvent[]                   @relation("ScoreEventActor")
  winnerRequests            WinnerRequest[]                @relation("WinnerRequestAuthor")
  reviewedRequests          WinnerRequest[]                @relation("WinnerRequestReviewer")
  communityWishProposals    CommunityWishProposal[]        @relation("CommunityWishProposalAuthor")
  communityWishVotes        CommunityWishVote[]            @relation("CommunityWishVoteVoter")
  communityWishEntitlements CommunityWishVoteEntitlement[] @relation("CommunityWishVoteEntitlementUser")
  buildArcadeRuns           BuildArcadeRun[]
  arcadeWallet              ArcadeWallet?
  arcadeTransactions        ArcadeTransaction[]
  arcadeLootBoxPurchases    ArcadeLootBoxPurchase[]
  arcadeCosmeticUnlocks     ArcadeCosmeticUnlock[]
  resolvedCommunityWishTies CycleHistory[]                 @relation("CommunityWishAdminResolver")
  wonCycles                 Cycle[]                        @relation("CycleWinner")
  cycleHistoriesWon         CycleHistory[]                 @relation("CycleHistoryWinner")
  unitCosmeticVariant       String?
  fortressCosmeticVariant   String?
  cosmeticUnlockedAt        DateTime?
}

model Account {
  id                       String   @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?  @db.Text
  access_token             String?  @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?  @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cycle {
  id                            String                         @id @default(cuid())
  status                        CycleStatus                    @default(REGISTRATION)
  registrationStartedAt         DateTime
  registrationEndsAt            DateTime
  testingStartedAt              DateTime?
  testingEndsAt                 DateTime?
  joiningLockedAt               DateTime?
  activeStartedAt               DateTime?
  activeEndsAt                  DateTime?
  resolvedAt                    DateTime?
  winnerId                      String?
  crownedFortressId             String?
  upgradesUnlockedAt            DateTime?
  megaFortressDestroyCount      Int                            @default(0)
  mapLayoutVersion              Int                            @default(1)
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  winner                        User?                          @relation("CycleWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  crownedFortress               Fortress?                      @relation("CycleCrownedFortress", fields: [crownedFortressId], references: [id], onDelete: SetNull)
  fortresses                    Fortress[]
  chatMessages                  ChatMessage[]
  scoreEvents                   ScoreEvent[]
  gameTicks                     GameTick[]
  attackUnits                   AttackUnit[]
  battlefields                  Battlefield[]
  mapHexOwnerships              MapHexOwnership[]
  mapHexClaimProjects           MapHexClaimProject[]
  castleUpgradeProjects         CastleUpgradeProject[]
  homeOfAHolders                HomeOfAHolder[]
  unicornTemporaryTeleports     UnicornTemporaryTeleport[]
  orkScrapBanks                 OrkScrapBank[]
  orkScrapEvents                OrkScrapEvent[]
  orkBossOrders                 OrkBossOrder[]
  orkWaaaghInvestments          OrkWaaaghInvestment[]
  winnerRequests                WinnerRequest[]
  communityWishProposals        CommunityWishProposal[]
  communityWishVoteEntitlements CommunityWishVoteEntitlement[]
  buildArcadeRuns               BuildArcadeRun[]
  arcadeTransactions            ArcadeTransaction[]
  history                       CycleHistory?

  @@index([status])
  @@index([winnerId])
  @@index([crownedFortressId])
}

model Fortress {
  id                           String                              @id @default(cuid())
  cycleId                      String
  ownerId                      String
  commanderName                String
  commanderNameRegisteredAt    DateTime?
  name                         String
  points                       Int                                 @default(0)
  gold                         Int                                 @default(0)
  level                        Int                                 @default(0)
  food                         Int                                 @default(0)
  army                         Int                                 @default(0)
  recruitmentQueue             Int                                 @default(0)
  minersAssigned               Int                                 @default(10)
  farmersAssigned              Int                                 @default(10)
  recruitersAssigned           Int                                 @default(5)
  race                         FortressRace?
  fortressKind                 FortressKind                        @default(PLAYER)
  lootCampVariant              LootCampVariant?
  isNpc                        Boolean                             @default(false)
  health                       Int                                 @default(0)
  maxHealth                    Int                                 @default(0)
  expiresAt                    DateTime?
  sizeTiles                    Int                                 @default(1)
  iconLabel                    String?
  unicornDecoySourceFortressId String?
  unicornDecoyLevel            Int?
  currentAction                FortressAction                      @default(GROW)
  targetFortressId             String?
  unitSpriteVariant            String                              @default("unit-1")
  locationShuffleCount         Int                                 @default(0)
  mapX                         Int
  mapY                         Int
  joinedAt                     DateTime                            @default(now())
  createdAt                    DateTime                            @default(now())
  updatedAt                    DateTime                            @updatedAt
  cycle                        Cycle                               @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  owner                        User                                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  targetFortress               Fortress?                           @relation("FortressTarget", fields: [targetFortressId], references: [id], onDelete: SetNull)
  attackers                    Fortress[]                          @relation("FortressTarget")
  unicornDecoySourceFortress   Fortress?                           @relation("UnicornDecoySource", fields: [unicornDecoySourceFortressId], references: [id], onDelete: Cascade)
  unicornDecoys                Fortress[]                          @relation("UnicornDecoySource")
  outboundAttackUnits          AttackUnit[]                        @relation("AttackUnitAttacker")
  inboundAttackUnits           AttackUnit[]                        @relation("AttackUnitTarget")
  crownedCycles                Cycle[]                             @relation("CycleCrownedFortress")
  scoreEventsAsFortress        ScoreEvent[]                        @relation("ScoreEventFortress")
  scoreEventsAsTarget          ScoreEvent[]                        @relation("ScoreEventTargetFortress")
  castleUpgradeSpecializations CastleUpgradeSpecializationChoice[]
  castleUpgradeProjects        CastleUpgradeProject[]
  raceAbilityActivations       RaceAbilityActivation[]
  orkScrapBank                 OrkScrapBank?
  orkScrapEvents               OrkScrapEvent[]                    @relation("OrkScrapEventFortress")
  orkScrapTargetedEvents       OrkScrapEvent[]                    @relation("OrkScrapEventTargetFortress")
  orkBossOrders                OrkBossOrder[]
  orkWaaaghInvestments         OrkWaaaghInvestment[]
  targetedRaceAbilityActivations RaceAbilityActivation[] @relation("RaceAbilityTargetFortress")
  runeRaceAbilityActivations   RaceAbilityActivation[] @relation("RaceAbilityRuneFortress")
  dwarfGrudges                 DwarfGrudge[]                       @relation("DwarfGrudgeOwner")
  grudgedBy                    DwarfGrudge[]                       @relation("DwarfGrudgeTarget")
  deepMiningRolls              DwarfDeepMiningRoll[]               @relation("DwarfDeepMiningOwner")
  deepMiningRuneRolls          DwarfDeepMiningRoll[]               @relation("DwarfDeepMiningRune")
  deepMiningTargetedBy         DwarfDeepMiningRoll[]               @relation("DwarfDeepMiningTarget")
  ownedMapHexes                MapHexOwnership[]                   @relation("MapHexOwner")
  mapHexClaimProjects          MapHexClaimProject[]                @relation("MapHexClaimProjectFortress")
  homeOfAHoldings              HomeOfAHolder[]                     @relation("HomeOfAHolderFortress")
  homeOfABannerHoldings        HomeOfAHolder[]                     @relation("HomeOfABannerFortress")
  attackerBannerBattlefields   Battlefield[]                       @relation("BattlefieldAttackerBanner")
  defenderBannerBattlefields   Battlefield[]                       @relation("BattlefieldDefenderBanner")
  targetedBattlefields         Battlefield[]                       @relation("BattlefieldTargetFortress")
  battlefieldParticipants      BattlefieldParticipant[]
  unicornTemporaryTeleports    UnicornTemporaryTeleport[]          @relation("UnicornTeleportFortress")
  unicornTemporaryTeleportDecoy UnicornTemporaryTeleport?           @relation("UnicornTeleportDecoy")

  @@unique([cycleId, ownerId])
  @@unique([cycleId, commanderName])
  @@unique([cycleId, name])
  @@index([cycleId])
  @@index([cycleId, isNpc])
  @@index([cycleId, fortressKind])
  @@index([cycleId, fortressKind, expiresAt])
  @@index([unicornDecoySourceFortressId, createdAt])
  @@index([ownerId])
}

model UnicornTemporaryTeleport {
  id             String    @id @default(cuid())
  cycleId        String
  fortressId     String
  decoyFortressId String?   @unique
  originMapX     Int
  originMapY     Int
  temporaryMapX  Int
  temporaryMapY  Int
  startedAt      DateTime
  returnAt       DateTime
  returnedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  cycle          Cycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress       Fortress  @relation("UnicornTeleportFortress", fields: [fortressId], references: [id], onDelete: Cascade)
  decoyFortress  Fortress? @relation("UnicornTeleportDecoy", fields: [decoyFortressId], references: [id], onDelete: SetNull)

  @@index([cycleId, returnAt, returnedAt])
  @@index([fortressId, returnedAt])
}

model MapHexOwnership {
  id              String   @id @default(cuid())
  cycleId         String
  tileId          String
  ownerFortressId String
  claimedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cycle           Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  ownerFortress   Fortress @relation("MapHexOwner", fields: [ownerFortressId], references: [id], onDelete: Cascade)

  @@unique([cycleId, tileId])
  @@index([ownerFortressId])
  @@index([cycleId, ownerFortressId])
}

model MapHexClaimProject {
  id          String    @id @default(cuid())
  cycleId     String
  fortressId  String
  tileId      String
  goldCost    Int
  startedAt   DateTime
  completesAt DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cycle       Cycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress    Fortress  @relation("MapHexClaimProjectFortress", fields: [fortressId], references: [id], onDelete: Cascade)

  @@index([cycleId, completedAt, completesAt])
  @@index([fortressId, completedAt])
  @@index([cycleId, tileId, completedAt])
}

model CastleUpgradeProject {
  id             String                       @id @default(cuid())
  cycleId        String
  fortressId     String
  level          Int
  specialization CastleUpgradeSpecialization
  goldCost       Int
  startedAt      DateTime
  completesAt    DateTime
  completedAt    DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  cycle          Cycle                        @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress       Fortress                     @relation(fields: [fortressId], references: [id], onDelete: Cascade)

  @@index([cycleId, completesAt, completedAt])
  @@index([fortressId, completedAt])
}

model HomeOfAHolder {
  id                String   @id @default(cuid())
  cycleId           String
  fortressId        String
  bannerFortressId  String
  contributionWeight Int
  capturedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  cycle             Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress          Fortress @relation("HomeOfAHolderFortress", fields: [fortressId], references: [id], onDelete: Cascade)
  bannerFortress    Fortress @relation("HomeOfABannerFortress", fields: [bannerFortressId], references: [id], onDelete: Cascade)

  @@unique([cycleId, fortressId])
  @@index([cycleId, bannerFortressId])
  @@index([fortressId])
}

model Battlefield {
  id                       String                    @id @default(cuid())
  cycleId                  String
  targetFortressId         String?
  targetTileId             String?
  attackerBannerFortressId String
  defenderBannerFortressId String?
  status                   BattlefieldStatus         @default(ACTIVE)
  progress                 Int                       @default(0)
  attackerArmyRemaining    Int                       @default(0)
  defenderArmyRemaining    Int                       @default(0)
  pointsReward             Int                       @default(0)
  foodReward               Int                       @default(0)
  resolvedWinnerSide       BattlefieldSide?
  startedAt                DateTime                  @default(now())
  resolvedAt               DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  cycle                    Cycle                     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  targetFortress           Fortress?                 @relation("BattlefieldTargetFortress", fields: [targetFortressId], references: [id], onDelete: Cascade)
  attackerBannerFortress   Fortress                  @relation("BattlefieldAttackerBanner", fields: [attackerBannerFortressId], references: [id], onDelete: Cascade)
  defenderBannerFortress   Fortress?                 @relation("BattlefieldDefenderBanner", fields: [defenderBannerFortressId], references: [id], onDelete: SetNull)
  participants             BattlefieldParticipant[]
  incomingReinforcements   AttackUnit[]              @relation("BattlefieldReinforcements")

  @@index([cycleId, status])
  @@index([targetFortressId, status])
  @@index([targetTileId, status])
}

model BattlefieldParticipant {
  id            String          @id @default(cuid())
  battlefieldId String
  fortressId    String
  side          BattlefieldSide
  armyCommitted Int
  armyRemaining Int
  joinedAt      DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  battlefield   Battlefield     @relation(fields: [battlefieldId], references: [id], onDelete: Cascade)
  fortress      Fortress        @relation(fields: [fortressId], references: [id], onDelete: Cascade)

  @@unique([battlefieldId, fortressId])
  @@index([fortressId])
  @@index([battlefieldId, side])
}

model DwarfDeepMiningRoll {
  id               String                  @id @default(cuid())
  fortressId       String
  targetFortressId String?
  runeFortressId   String?                 @unique
  outcome          DwarfDeepMiningOutcome
  committedGold    Int                     @default(0)
  goldDelta        Int                     @default(0)
  armyDelta        Int                     @default(0)
  recruitmentQueueDelta Int                @default(0)
  resolvedAt       DateTime?
  activeUntil      DateTime?
  createdAt        DateTime                @default(now())
  fortress         Fortress                @relation("DwarfDeepMiningOwner", fields: [fortressId], references: [id], onDelete: Cascade)
  targetFortress   Fortress?               @relation("DwarfDeepMiningTarget", fields: [targetFortressId], references: [id], onDelete: SetNull)
  runeFortress     Fortress?               @relation("DwarfDeepMiningRune", fields: [runeFortressId], references: [id], onDelete: SetNull)

  @@index([fortressId, createdAt])
  @@index([targetFortressId, activeUntil])
  @@index([outcome, createdAt])
}

model CastleUpgradeSpecializationChoice {
  id             String                      @id @default(cuid())
  fortressId     String
  level          Int
  specialization CastleUpgradeSpecialization
  createdAt      DateTime                    @default(now())
  fortress       Fortress                    @relation(fields: [fortressId], references: [id], onDelete: Cascade)

  @@unique([fortressId, specialization, level])
  @@index([fortressId, specialization])
}

model RaceAbilityActivation {
  id                    String          @id @default(cuid())
  fortressId            String
  kind                  RaceAbilityKind
  activeFrom            DateTime
  activeUntil           DateTime
  usedAt                DateTime        @default(now())
  expiresAt             DateTime?
  consumedAt            DateTime?
  targetFortressId      String?
  runeFortressId        String?
  goldCost              Int             @default(0)
  maintenanceGoldPerTick Int             @default(0)
  createdAt             DateTime        @default(now())
  fortress              Fortress        @relation(fields: [fortressId], references: [id], onDelete: Cascade)
  targetFortress        Fortress?       @relation("RaceAbilityTargetFortress", fields: [targetFortressId], references: [id], onDelete: SetNull)
  runeFortress          Fortress?       @relation("RaceAbilityRuneFortress", fields: [runeFortressId], references: [id], onDelete: SetNull)
  orkWaaaghInvestments  OrkWaaaghInvestment[]

  @@index([fortressId, kind, usedAt])
  @@index([fortressId, kind, activeUntil])
  @@index([fortressId, kind, expiresAt, consumedAt])
  @@index([targetFortressId, kind, activeUntil])
  @@index([runeFortressId, kind, activeUntil])
}

model OrkScrapBank {
  id         String   @id @default(cuid())
  cycleId    String
  fortressId String   @unique
  scrap      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  cycle      Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress   Fortress @relation(fields: [fortressId], references: [id], onDelete: Cascade)

  @@unique([cycleId, fortressId])
  @@index([cycleId])
}

model OrkScrapEvent {
  id               String              @id @default(cuid())
  cycleId          String
  fortressId       String
  reason           OrkScrapEventReason
  delta            Int
  balanceAfter     Int
  targetFortressId String?
  tileId           String?
  battlefieldId    String?
  attackUnitId     String?
  bossOrderId      String?
  waaaghInvestmentId String?
  createdAt        DateTime            @default(now())
  cycle            Cycle               @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress         Fortress            @relation("OrkScrapEventFortress", fields: [fortressId], references: [id], onDelete: Cascade)
  targetFortress   Fortress?           @relation("OrkScrapEventTargetFortress", fields: [targetFortressId], references: [id], onDelete: SetNull)
  bossOrder        OrkBossOrder?        @relation(fields: [bossOrderId], references: [id], onDelete: SetNull)
  waaaghInvestment OrkWaaaghInvestment? @relation(fields: [waaaghInvestmentId], references: [id], onDelete: SetNull)

  @@index([cycleId, fortressId, createdAt])
  @@index([targetFortressId])
  @@index([battlefieldId])
  @@index([attackUnitId])
}

model OrkBossOrder {
  id          String           @id @default(cuid())
  cycleId     String
  fortressId  String
  kind        OrkBossOrderKind
  scrapCost   Int
  goldCost    Int
  activeFrom  DateTime
  activeUntil DateTime
  usedAt      DateTime         @default(now())
  createdAt   DateTime         @default(now())
  cycle       Cycle            @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress    Fortress         @relation(fields: [fortressId], references: [id], onDelete: Cascade)
  scrapEvents OrkScrapEvent[]

  @@index([cycleId, fortressId, activeUntil])
  @@index([fortressId, kind, usedAt])
}

model OrkWaaaghInvestment {
  id                 String                  @id @default(cuid())
  cycleId            String
  fortressId         String
  waaaghActivationId String
  kind               OrkWaaaghInvestmentKind
  scrapCost          Int
  createdAt          DateTime                @default(now())
  cycle              Cycle                   @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress           Fortress                @relation(fields: [fortressId], references: [id], onDelete: Cascade)
  waaaghActivation   RaceAbilityActivation   @relation(fields: [waaaghActivationId], references: [id], onDelete: Cascade)
  scrapEvents        OrkScrapEvent[]

  @@unique([waaaghActivationId, kind])
  @@index([cycleId, fortressId, createdAt])
}

model DwarfGrudge {
  id               String   @id @default(cuid())
  fortressId       String
  targetFortressId String
  slot             Int
  bonusMultiplier  Int      @default(1)
  createdAt        DateTime @default(now())
  fortress         Fortress @relation("DwarfGrudgeOwner", fields: [fortressId], references: [id], onDelete: Cascade)
  targetFortress   Fortress @relation("DwarfGrudgeTarget", fields: [targetFortressId], references: [id], onDelete: Cascade)

  @@unique([fortressId, slot])
  @@unique([fortressId, targetFortressId])
  @@index([targetFortressId])
}

model AttackUnit {
  id                        String    @id @default(cuid())
  cycleId                   String
  attackerFortressId        String
  targetFortressId          String
  reinforcementBattlefieldId String?
  reinforcementSide         BattlefieldSide?
  armyAmount                Int       @default(1)
  defenderArmyAtBattleStart Int?
  resolvedAttackPower       Int?
  resolvedDefensePower      Int?
  attackerSurvivors         Int?
  attackerRetired           Int?
  attackerReturned          Int?
  defenderLosses            Int?
  pointsLooted              Int?
  foodLooted                Int?
  armyLooted                Int?
  launchedAt                DateTime
  arrivesAt                 DateTime
  recalledAt                DateTime?
  returnOriginMapX          Int?
  returnOriginMapY          Int?
  resolvedAt                DateTime?
  cancelledAt               DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  cycle                     Cycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  attackerFortress          Fortress  @relation("AttackUnitAttacker", fields: [attackerFortressId], references: [id], onDelete: Cascade)
  targetFortress            Fortress  @relation("AttackUnitTarget", fields: [targetFortressId], references: [id], onDelete: Cascade)
  reinforcementBattlefield  Battlefield? @relation("BattlefieldReinforcements", fields: [reinforcementBattlefieldId], references: [id], onDelete: SetNull)

  @@index([cycleId, arrivesAt])
  @@index([reinforcementBattlefieldId, arrivesAt])
  @@index([attackerFortressId, resolvedAt, cancelledAt])
  @@index([targetFortressId])
}

model ChatMessage {
  id            String          @id @default(cuid())
  cycleId       String
  authorId      String
  type          ChatMessageType @default(TEXT)
  body          String          @db.Text
  gifProvider   String?
  gifProviderId String?
  gifTitle      String?         @db.Text
  gifPreviewUrl String?         @db.Text
  gifDisplayUrl String?         @db.Text
  gifWidth      Int?
  gifHeight     Int?
  gifSourceUrl  String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  cycle         Cycle           @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  author        User            @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([cycleId, createdAt])
  @@index([authorId, createdAt])
}

model ScoreEvent {
  id               String         @id @default(cuid())
  cycleId          String
  fortressId       String
  actorId          String?
  targetFortressId String?
  eventType        ScoreEventType
  delta            Int
  createdAt        DateTime       @default(now())
  cycle            Cycle          @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fortress         Fortress       @relation("ScoreEventFortress", fields: [fortressId], references: [id], onDelete: Cascade)
  actor            User?          @relation("ScoreEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetFortress   Fortress?      @relation("ScoreEventTargetFortress", fields: [targetFortressId], references: [id], onDelete: SetNull)

  @@index([cycleId, createdAt])
  @@index([fortressId, createdAt])
  @@index([actorId])
}

model GameTick {
  id        String   @id @default(cuid())
  cycleId   String
  tickAt    DateTime
  createdAt DateTime @default(now())
  cycle     Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, tickAt])
  @@index([tickAt])
}

model WinnerRequest {
  id                    String              @id @default(cuid())
  cycleId               String
  authorId              String
  reviewedById          String?
  requestText           String              @db.Text
  status                WinnerRequestStatus @default(SUBMITTED)
  reviewNotes           String?             @db.Text
  fulfillmentProgress   Int                 @default(0)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  reviewedAt            DateTime?
  cycle                 Cycle               @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  author                User                @relation("WinnerRequestAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reviewedBy            User?               @relation("WinnerRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  cycleHistoryReference CycleHistory?       @relation("CycleHistoryWinnerRequest")

  @@unique([cycleId, authorId])
  @@index([cycleId, status])
}

model CommunityWishProposal {
  id                    String              @id @default(cuid())
  cycleId               String
  authorId              String
  requestText           String              @db.Text
  status                WinnerRequestStatus @default(SUBMITTED)
  reviewNotes           String?             @db.Text
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  cycle                 Cycle               @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  author                User                @relation("CommunityWishProposalAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  votes                 CommunityWishVote[]
  cycleHistoryReference CycleHistory?       @relation("CycleHistoryCommunityWish")

  @@unique([cycleId, authorId])
  @@index([cycleId, createdAt])
}

model BuildArcadeRun {
  id            String   @id @default(cuid())
  cycleId       String
  userId        String
  score         Int      @default(0)
  rewardVariant String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cycle         Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cycleId, userId])
  @@index([cycleId, score])
  @@index([userId])
}

model ArcadeWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([balance])
}

model ArcadeTransaction {
  id           String                @id @default(cuid())
  userId       String
  cycleId      String?
  kind         ArcadeTransactionKind
  gameType     ArcadeGameType?
  amount       Int
  balanceAfter Int
  summary      String                @db.Text
  details      String?               @db.Text
  dedupeKey    String?               @unique
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle        Cycle?                @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([cycleId, createdAt])
}

model ArcadeLootBoxPurchase {
  id              String                @id @default(cuid())
  userId          String
  crateType       ArcadeLootBoxType
  price           Int
  openedAt        DateTime?
  rewardSlot      ArcadeCosmeticSlot?
  rewardVariant   String?
  duplicatePayout Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlock          ArcadeCosmeticUnlock?

  @@index([userId, createdAt])
  @@index([userId, openedAt])
}

model ArcadeCosmeticUnlock {
  id               String                 @id @default(cuid())
  userId           String
  slot             ArcadeCosmeticSlot
  variant          String
  sourcePurchaseId String?                @unique
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePurchase   ArcadeLootBoxPurchase? @relation(fields: [sourcePurchaseId], references: [id], onDelete: SetNull)

  @@unique([userId, slot, variant])
  @@index([userId, slot])
}

model CommunityWishVote {
  id         String                @id @default(cuid())
  proposalId String
  voterId    String
  votes      Int
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  proposal   CommunityWishProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voter      User                  @relation("CommunityWishVoteVoter", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([proposalId, voterId])
  @@index([voterId])
}

model CommunityWishVoteEntitlement {
  id         String   @id @default(cuid())
  cycleId    String
  userId     String
  rank       Int
  voteBudget Int
  createdAt  DateTime @default(now())
  cycle      Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user       User     @relation("CommunityWishVoteEntitlementUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cycleId, userId])
  @@index([userId])
}

model CycleHistory {
  id                               String                 @id @default(cuid())
  cycleId                          String                 @unique
  winnerId                         String
  winnerRequestId                  String?                @unique
  communityWishProposalId          String?                @unique
  winningScore                     Int
  endedAt                          DateTime
  firstSlayerCommanderName         String?                @db.Text
  firstSlayerFortressName          String?                @db.Text
  tieBreakSummary                  String?                @db.Text
  winnerRequestSnapshot            String?                @db.Text
  communityWishSnapshot            String?                @db.Text
  communityWishVoteCount           Int                    @default(0)
  communityWishFulfillmentProgress Int                    @default(0)
  communityWishStatus              CommunityWishStatus    @default(NO_PROPOSALS)
  communityWishProposalEndsAt      DateTime?
  communityWishVotingEndsAt        DateTime?
  communityWishResolvedAt          DateTime?
  communityWishResolvedById        String?
  createdAt                        DateTime               @default(now())
  cycle                            Cycle                  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  winner                           User                   @relation("CycleHistoryWinner", fields: [winnerId], references: [id], onDelete: Restrict)
  winnerRequest                    WinnerRequest?         @relation("CycleHistoryWinnerRequest", fields: [winnerRequestId], references: [id], onDelete: SetNull)
  communityWishProposal            CommunityWishProposal? @relation("CycleHistoryCommunityWish", fields: [communityWishProposalId], references: [id], onDelete: SetNull)
  communityWishResolvedBy          User?                  @relation("CommunityWishAdminResolver", fields: [communityWishResolvedById], references: [id], onDelete: SetNull)

  @@index([winnerId])
  @@index([endedAt])
  @@index([communityWishStatus, communityWishProposalEndsAt])
  @@index([communityWishStatus, communityWishVotingEndsAt])
  @@index([communityWishResolvedById])
}
