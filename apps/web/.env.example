NEXT_PUBLIC_APP_NAME=Project-A
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LOCAL DEVELOPMENT ONLY. Replace with strong random values in production.
AUTH_SECRET=replace-with-a-long-random-string
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=replace-me
AUTH_GOOGLE_SECRET=replace-me
ALLOWED_ORIGINS=http://localhost:3000

# LOCAL DEVELOPMENT ONLY. Never use default postgres credentials in production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_a?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/project_a?schema=public
ADMIN_EMAIL=admin@example.com

# Optional for non-Render production proxies. Keep false by default.
# TRUST_PROXY_HEADERS=false
