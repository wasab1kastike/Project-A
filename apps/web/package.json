{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.mjs --dev",
    "prebuild": "prisma generate --schema prisma/schema.prisma",
    "build": "next build",
    "start": "node server.mjs",
    "game:tick": "tsx src/lib/game/tick-cli.ts",
    "god:run": "tsx src/lib/openclaw/god-runner.ts",
    "lint": "eslint",
    "test:game": "tsx --test src/lib/game/game.test.ts",
    "typecheck": "tsc --noEmit",
    "db:dev": "prisma dev --name project-a",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "prisma db seed --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "db:grant-home-of-a-drain-compensation": "tsx prisma/grant-home-of-a-drain-compensation.ts",
    "db:grant-may-15-player-compensation": "tsx prisma/grant-may-15-player-compensation.ts",
    "db:grant-may-18-combat-compensation": "tsx prisma/grant-may-18-combat-compensation.ts",
    "db:schedule-current-season-early-end": "tsx prisma/schedule-current-season-early-end.ts",
    "db:reset-season-one": "tsx prisma/reset-season-one.ts",
    "db:allocate-season-one-coins": "tsx prisma/allocate-season-one-coins.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "typescript": "^5"
  }
}
